<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/obs_sheet_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/text_obs_step_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="20dp"
            tools:text="Paso #1 · Verificar extintor" />

        <!-- Selector de tipo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/obs_type_label"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/radio_group_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/radio_observation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/obs_type_observation"
                android:checked="true"
                android:textSize="15sp" />

            <RadioButton
                android:id="@+id/radio_deficiency"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/obs_type_deficiency"
                android:textSize="15sp" />

        </RadioGroup>

        <!-- Chip de aviso para Deficiencia -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_deficiency_warning"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/obs_deficiency_warning"
            app:chipBackgroundColor="@color/deficiency_warning_bg"
            app:chipIcon="@android:drawable/ic_dialog_alert"
            android:textColor="@color/deficiency_warning_text"
            android:textSize="12sp"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            tools:visibility="visible" />

        <!-- Descripción -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_obs_description"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/obs_description_hint"
            app:errorEnabled="true"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_obs_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="3"
                android:maxLines="6"
                android:gravity="top|start" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Sección foto -->
        <TextView
            android:id="@+id/text_photo_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/obs_photo_label_optional"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Vista previa de la foto -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">

            <ImageView
                android:id="@+id/image_obs_photo_preview"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_photo_placeholder"
                android:contentDescription="@string/obs_photo_preview_desc"
                android:visibility="gone"
                tools:visibility="visible"
                tools:src="@android:drawable/ic_menu_camera" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_remove_photo"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:text="@string/obs_remove_photo"
                android:textColor="@android:color/holo_red_dark"
                android:visibility="gone"
                tools:visibility="visible" />

        </FrameLayout>

        <!-- Tarjeta de metadatos de la foto (visible cuando hay foto adjunta) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_photo_metadata"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            app:cardElevation="0dp"
            app:cardBackgroundColor="?attr/colorSurfaceVariant"
            app:cardCornerRadius="8dp"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/meta_section_title"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="?android:attr/textColorSecondary"
                    android:layout_marginBottom="8dp" />

                <!-- Fila: Timestamp -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="24dp"
                        android:layout_height="wrap_content"
                        android:text="📅"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/text_meta_timestamp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="13sp"
                        tools:text="17/03/2026 14:30:22" />

                </LinearLayout>

                <!-- Fila: GPS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="24dp"
                        android:layout_height="wrap_content"
                        android:text="📍"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/text_meta_gps"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="13sp"
                        tools:text="-31.416700°, -64.183500°" />

                    <ProgressBar
                        android:id="@+id/progress_gps"
                        style="?android:attr/progressBarStyleSmall"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:visibility="gone"
                        tools:visibility="visible" />

                </LinearLayout>

                <!-- Fila: Inspector -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="24dp"
                        android:layout_height="wrap_content"
                        android:text="👤"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/text_meta_inspector"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="13sp"
                        tools:text="Juan García" />

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Error de foto requerida -->
        <TextView
            android:id="@+id/text_photo_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/obs_photo_required_error"
            android:textColor="@color/design_default_color_error"
            android:textSize="12sp"
            android:visibility="gone"
            android:layout_marginBottom="4dp"
            tools:visibility="visible" />

        <!-- Botones de foto -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_take_photo"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/obs_take_photo"
                app:icon="@android:drawable/ic_menu_camera"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pick_gallery"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/obs_pick_gallery"
                app:icon="@android:drawable/ic_menu_gallery" />

        </LinearLayout>

        <!-- Botones de acción -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cancel_obs"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_cancel"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_obs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/obs_btn_save" />

        </LinearLayout>

        <ProgressBar
            android:id="@+id/progress_obs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            tools:visibility="visible" />

    </LinearLayout>
</ScrollView>
