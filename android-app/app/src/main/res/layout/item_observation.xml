<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingTop="6dp"
    android:paddingBottom="6dp"
    android:paddingStart="4dp"
    android:paddingEnd="4dp"
    android:gravity="center_vertical">

    <!-- Icono según tipo: info (observación) o alerta (deficiencia) -->
    <ImageView
        android:id="@+id/icon_obs_type"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginEnd="8dp"
        android:src="@android:drawable/ic_dialog_info"
        android:contentDescription="@string/obs_type_label"
        tools:tint="@color/obs_remark_color" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/text_obs_type_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textStyle="bold"
            tools:text="DEFICIENCIA"
            tools:textColor="@color/obs_deficiency_color" />

        <TextView
            android:id="@+id/text_obs_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end"
            tools:text="Extintor con presión baja, requiere recarga inmediata." />

    </LinearLayout>

    <!-- Miniatura de foto si aplica -->
    <ImageView
        android:id="@+id/image_obs_thumb"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="8dp"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_photo_placeholder"
        android:visibility="gone"
        android:contentDescription="@string/obs_photo_preview_desc"
        tools:visibility="visible"
        tools:src="@android:drawable/ic_menu_camera" />

</LinearLayout>
